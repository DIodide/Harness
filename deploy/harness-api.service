[Unit]
Description=Harness FastAPI Backend (Production)
After=network.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/opt/harness-api
EnvironmentFile=/opt/harness-api/.env
ExecStart=/opt/harness-api/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
