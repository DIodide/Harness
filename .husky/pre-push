branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$branch" = "main" ]; then
  echo "Direct pushes to main are not allowed. Use a feature branch and open a PR."
  exit 1
fi

valid_pattern="^(feat|fix|chore|docs|refactor|test|ci|style|perf)/.+$"

if ! echo "$branch" | grep -qE "$valid_pattern"; then
  echo "Invalid branch name: $branch"
  echo "Branch names must follow: <type>/<description>"
  echo "Allowed types: feat, fix, chore, docs, refactor, test, ci, style, perf"
  echo "Example: feat/add-user-auth"
  exit 1
fi
