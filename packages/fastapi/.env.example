OPENROUTER_API_KEY=
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOY_KEY=
FRONTEND_URL=http://localhost:3001

# Daytona Sandbox (get API key from https://app.daytona.io)
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

# Encrypts per-user agent credentials (AES-256-GCM). Required to connect agents.
AGENT_CREDENTIALS_KEY=

# LOCAL DEVELOPMENT ONLY — skip Clerk JWT verification; treat every request as a
# fixed dev user. Pair with the web app's VITE_ENABLE_DEV_AUTH and Convex's
# ENABLE_DEV_AUTH. NEVER set this in production.
# ENABLE_DEV_AUTH=true
